    "with open('sales_data.txt', 'r') as f:\n",
    "    raw = f.readlines()\n",
    "    sales_list = [int(line.strip()) for line in raw if line.strip()]\n",
    "print(sales_list)\n",
    "print(sum(sales_list))\n",
    "print(max(sales_list))\n",
    "print(min(sales_list))\n",
    "print(sum(sales_list)/len(sales_list))\n"
   ]
  }
