   "source": [
    "def  factorial(num):\n",
    "    fact = 1\n",
    "    if num == 0 or num == 1:\n",
    "        return 1\n",
    "    elif num < 0:\n",
    "        print(\"error\")\n",
    "    else:\n",
    "        return  num * factorial(num - 1)"
   ]
